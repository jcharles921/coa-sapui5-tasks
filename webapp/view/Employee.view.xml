<mvc:View
    controllerName="coasapui5task1jc.controller.Employee"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
>
    <Page
        id="employeeDetails"
        title="Employee Details"
        showNavButton="true"
        navButtonPress="onNavBack"
        class="sapUiResponsivePadding--header sapUiResponsivePadding--content sapUiResponsivePadding--footer"
    >
        <content>
            <Panel
                id="employeePanel"
                headerText="Employee Information"
                class="sapUiResponsiveMargin"
                width="auto"
                expandable="false"
            >
                <content>
                    <f:SimpleForm
                        id="employeeDetailsForm"
                        editable="false"
                        layout="ResponsiveGridLayout"
                        labelSpanXL="3"
                        labelSpanL="3"
                        labelSpanM="3"
                        labelSpanS="12"
                        adjustLabelSpan="false"
                        emptySpanXL="4"
                        emptySpanL="4"
                        emptySpanM="4"
                        emptySpanS="0"
                        columnsXL="1"
                        columnsL="1"
                        columnsM="1"
                        singleContainerFullSize="false"
                    >
                        <f:content>
                            <!-- Employee ID -->
                            <Label
                                id="idLabel"
                                text="{i18n>employeeIdLabel}"
                                design="Bold"
                            />
                            <Text
                                id="idText"
                                text="{EmployeeV2Model>id}"
                            />

                            <!-- Employee Name -->
                            <Label
                                id="nameLabel"
                                text="{i18n>employeeNameLabel}"
                                design="Bold"
                            />
                            <Text
                                id="nameText"
                                text="{EmployeeV2Model>name}"
                            />

                            <!-- Employee Role -->
                            <Label
                                id="roleLabel"
                                text="{i18n>employeeRoleLabel}"
                                design="Bold"
                            />
                            <Text
                                id="roleText"
                                text="{EmployeeV2Model>role}"
                            />

                            <!-- Employee Salary -->
                            <Label
                                id="salaryLabel"
                                text="{i18n>employeeSalaryLabel}"
                                design="Bold"
                            />
                            <Text
                                id="salaryText"
                                text="{
                                    path: 'EmployeeV2Model>salary',
                                    formatter: '.formatter.formatCurrency'
                                }"
                            />
                        </f:content>
                    </f:SimpleForm>
                </content>
            </Panel>
        </content>

        <footer>
            <Toolbar
            id="toolBar"
            >
                <ToolbarSpacer 
                id="tollbarSpacer"
                />
                <Button
                    id="editButton"
                    text="Edit Employee"
                    type="Emphasized"
                    icon="sap-icon://edit"
                    press="onEditEmployee"
                />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>